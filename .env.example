# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ============================================================

# Get this from @BotFather on Telegram
BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram user ID (get it from @userinfobot)
OWNER_TG_ID=your-owner-telegram-id-here

# Comma-separated Telegram IDs of coaches
COACH_TG_IDS=id1,id2

# Google Sheets spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/<ID>/edit)
SPREADSHEET_ID=your-google-spreadsheet-id-here
